APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=investapremier
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

NOCAPTCHA_SITEKEY=
NOCAPTCHA_SECRET=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

YFAPI_KEY=
YFAPI_ENABLED=false
YFAPI_URL=https://yfapi.net
YAHOO_FINANCE_CHART_URL=https://query1.finance.yahoo.com/v8/finance/chart
DATA_EXTRACTION_QUEUE=extraction
DATA_EXTRACTION_HTTP_TIMEOUT=20
DATA_EXTRACTION_HTTP_RETRY=3
DATA_EXTRACTION_HTTP_RETRY_SLEEP_MS=500
DATA_EXTRACTION_JOB_TIMEOUT=120
DATA_EXTRACTION_JOB_TRIES=1
IDX_BOND_EXTRACTION_URL=
IDX_STOCK_EXTRACTION_URL=
PHEI_BOND_EXTRACTION_URL=
PHEI_NEWS_EXTRACTION_URL=
YAHOO_FINANCE_SEARCH_URL=https://query1.finance.yahoo.com/v1/finance/search

# Playwright browser cache.
# Leave blank on local dev (Playwright uses ~/.cache/ms-playwright by default).
# On production, set to a path the web server user can read, e.g.:
#   PLAYWRIGHT_BROWSERS_PATH=/var/www/.cache/ms-playwright
PLAYWRIGHT_BROWSERS_PATH=
